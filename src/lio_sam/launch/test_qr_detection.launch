<!-- QR码检测测试启动文件 -->
<!-- 同时启动 D435 相机和 QR 检测节点 -->

<launch>
    <arg name="marker_size" default="0.14" doc="QR码物理边长(米)，默认14cm"/>
    <arg name="publish_image" default="false" doc="是否发布可视化图像（上线建议关闭）"/>
    <arg name="confidence_threshold" default="0.55" doc="最小发布置信度"/>

    <arg name="image_topic" default="/camera/color/image_raw"/>
    <arg name="camera_info_topic" default="/camera/color/camera_info"/>
    <arg name="pose_topic" default="/qr_detection/pose"/>
    <arg name="detection_topic" default="/qr_detection/detection"/>
    <arg name="debug_image_topic" default="/qr_detection/image"/>
    <arg name="camera_frame" default="camera_color_optical_frame"/>
    <arg name="dictionary_name" default="DICT_6X6_250"/>

    <arg name="adaptive_thresh_win_size_min" default="3"/>
    <arg name="adaptive_thresh_win_size_max" default="23"/>
    <arg name="adaptive_thresh_win_size_step" default="10"/>
    <arg name="adaptive_thresh_constant" default="7.0"/>
    <arg name="min_marker_perimeter_rate" default="0.03"/>
    <arg name="polygonal_approx_accuracy_rate" default="0.03"/>
    <arg name="debug_axis_length" default="0.1"/>

    <include file="$(find realsense2_camera)/launch/rs_camera.launch">
        <arg name="align_depth" value="true"/>
        <arg name="enable_color" value="true"/>
        <arg name="color_width" value="1280"/>
        <arg name="color_height" value="720"/>
        <arg name="color_fps" value="30"/>
    </include>

    <include file="$(find lio_sam)/launch/include/module_qr_detection.launch">
        <arg name="project" value="lio_sam"/>
        <arg name="image_topic" value="$(arg image_topic)"/>
        <arg name="camera_info_topic" value="$(arg camera_info_topic)"/>
        <arg name="pose_topic" value="$(arg pose_topic)"/>
        <arg name="detection_topic" value="$(arg detection_topic)"/>
        <arg name="debug_image_topic" value="$(arg debug_image_topic)"/>
        <arg name="camera_frame" value="$(arg camera_frame)"/>
        <arg name="dictionary_name" value="$(arg dictionary_name)"/>
        <arg name="marker_size" value="$(arg marker_size)"/>
        <arg name="confidence_threshold" value="$(arg confidence_threshold)"/>
        <arg name="publish_image" value="$(arg publish_image)"/>
        <arg name="adaptive_thresh_win_size_min" value="$(arg adaptive_thresh_win_size_min)"/>
        <arg name="adaptive_thresh_win_size_max" value="$(arg adaptive_thresh_win_size_max)"/>
        <arg name="adaptive_thresh_win_size_step" value="$(arg adaptive_thresh_win_size_step)"/>
        <arg name="adaptive_thresh_constant" value="$(arg adaptive_thresh_constant)"/>
        <arg name="min_marker_perimeter_rate" value="$(arg min_marker_perimeter_rate)"/>
        <arg name="polygonal_approx_accuracy_rate" value="$(arg polygonal_approx_accuracy_rate)"/>
        <arg name="debug_axis_length" value="$(arg debug_axis_length)"/>
    </include>

    <node pkg="rqt_image_view" type="rqt_image_view" name="qr_image_view"
          args="$(arg debug_image_topic)" if="$(arg publish_image)"/>

</launch>
