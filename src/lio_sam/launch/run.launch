<launch>

    <arg name="project" default="lio_sam"/>

    <arg name="use_navsat" default="false"/>
    <arg name="use_qr_detection" default="true"/>

    <arg name="qr_marker_size" default="0.14"/>
    <arg name="qr_confidence_threshold" default="0.55"/>
    <arg name="qr_publish_image" default="false"/>
    <arg name="qr_image_topic" default="/camera/color/image_raw"/>
    <arg name="qr_camera_info_topic" default="/camera/color/camera_info"/>
    <arg name="qr_pose_topic" default="/qr_detection/pose"/>
    <arg name="qr_detection_topic" default="/qr_detection/detection"/>
    <arg name="qr_debug_image_topic" default="/qr_detection/image"/>
    <arg name="qr_camera_frame" default="camera_color_optical_frame"/>
    <arg name="qr_dictionary_name" default="DICT_6X6_250"/>

    <arg name="qr_adaptive_thresh_win_size_min" default="3"/>
    <arg name="qr_adaptive_thresh_win_size_max" default="23"/>
    <arg name="qr_adaptive_thresh_win_size_step" default="10"/>
    <arg name="qr_adaptive_thresh_constant" default="7.0"/>
    <arg name="qr_min_marker_perimeter_rate" default="0.03"/>
    <arg name="qr_polygonal_approx_accuracy_rate" default="0.03"/>
    <arg name="qr_debug_axis_length" default="0.1"/>

    <rosparam file="$(find lio_sam)/config/params.yaml" command="load" />
    <rosparam file="$(find lio_sam)/config/qr_landmarks.yaml" command="load" />

    <include file="$(find lio_sam)/launch/include/module_loam.launch" />

    <group if="$(arg use_qr_detection)">
        <include file="$(find lio_sam)/launch/include/module_qr_detection.launch">
            <arg name="project" value="$(arg project)"/>
            <arg name="image_topic" value="$(arg qr_image_topic)"/>
            <arg name="camera_info_topic" value="$(arg qr_camera_info_topic)"/>
            <arg name="pose_topic" value="$(arg qr_pose_topic)"/>
            <arg name="detection_topic" value="$(arg qr_detection_topic)"/>
            <arg name="debug_image_topic" value="$(arg qr_debug_image_topic)"/>
            <arg name="camera_frame" value="$(arg qr_camera_frame)"/>
            <arg name="dictionary_name" value="$(arg qr_dictionary_name)"/>
            <arg name="marker_size" value="$(arg qr_marker_size)"/>
            <arg name="confidence_threshold" value="$(arg qr_confidence_threshold)"/>
            <arg name="publish_image" value="$(arg qr_publish_image)"/>
            <arg name="adaptive_thresh_win_size_min" value="$(arg qr_adaptive_thresh_win_size_min)"/>
            <arg name="adaptive_thresh_win_size_max" value="$(arg qr_adaptive_thresh_win_size_max)"/>
            <arg name="adaptive_thresh_win_size_step" value="$(arg qr_adaptive_thresh_win_size_step)"/>
            <arg name="adaptive_thresh_constant" value="$(arg qr_adaptive_thresh_constant)"/>
            <arg name="min_marker_perimeter_rate" value="$(arg qr_min_marker_perimeter_rate)"/>
            <arg name="polygonal_approx_accuracy_rate" value="$(arg qr_polygonal_approx_accuracy_rate)"/>
            <arg name="debug_axis_length" value="$(arg qr_debug_axis_length)"/>
        </include>
    </group>

    <include file="$(find lio_sam)/launch/include/module_robot_state_publisher.launch" />

    <group if="$(arg use_navsat)">
        <include file="$(find lio_sam)/launch/include/module_navsat.launch" />
    </group>

    <include file="$(find lio_sam)/launch/include/module_rviz.launch" />

</launch>
